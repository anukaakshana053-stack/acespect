{
  "expo": {
    "name": "acespect-mobile",
    "slug": "acespect-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.acespect.app"
    },
    "android": {
      "package": "com.acespect.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "ACE SPECT uses your photos to attach inspection evidence.",
          "cameraPermission": "ACE SPECT uses your camera to capture inspection photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ACE SPECT uses your location to GPS-stamp inspections and confirm the property address."
        }
      ],
      "expo-build-properties",
      "@morrowdigital/watermelondb-expo-plugin"
    ],
    "extra": {
      "eas": {
        "projectId": "3367546c-c603-419a-854b-deb28159268f"
      }
    },
    "owner": "anuka02"
  }
}
