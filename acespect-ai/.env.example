# Anthropic API key. If unset, the service runs in STUB mode (deterministic
# fake agent outputs) so the pipeline is testable without spending tokens.
ANTHROPIC_API_KEY=

# Force stub mode even when a key is present (useful for local wiring tests).
STUB_MODE=0

# Per-agent model IDs. Defaults match the cost/latency tiering in the design:
# cheap structured work on Haiku, vision on Sonnet, hard reasoning on Opus.
MODEL_FORM=claude-haiku-4-5
MODEL_PHOTO=claude-sonnet-4-6
MODEL_RISK=claude-opus-4-8
MODEL_SUMMARY=claude-opus-4-8

PORT=8000
