# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated allowed origins, or * for any (dev only)
CORS_ORIGIN=*

# ── Database (PostgreSQL) ──────────────────────────────
# Local Postgres (e.g. the Docker one in README):
DATABASE_URL=postgresql://acespect:acespect@localhost:5432/acespect?schema=public
# Supabase (Project Settings → Database → Connection string → "URI").
# Use the pooled "Transaction" connection on port 6543 for serverless,
# or the direct 5432 string for long-lived servers + migrations:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ── JWT ────────────────────────────────────────────────
# Generate strong secrets:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

# ── Google sign-in (optional) ──────────────────────────
# Comma-separated Google OAuth client IDs allowed as the `aud` of incoming
# ID tokens (the web + iOS + Android client IDs from Google Cloud Console).
# Leave empty to disable Google sign-in (the /auth/google route returns 501).
GOOGLE_CLIENT_IDS=
